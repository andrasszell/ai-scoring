# Copy to .env and fill in. Only SEC_USER_AGENT is required.

# Required by SEC EDGAR fair-access policy: use a real contact.
# Format: "Your Name your.email@example.com"
SEC_USER_AGENT="ai-collect contact@example.com"

# Optional API keys. Collectors that lack their key are skipped gracefully.
FMP_API_KEY=""                 # earnings-call transcripts (Financial Modeling Prep)
SERPAPI_API_KEY=""             # product/service and hiring evidence (SerpAPI)
SEMANTIC_SCHOLAR_API_KEY=""    # research papers; optional but avoids 429 rate limiting
PATENTSVIEW_API_KEY=""         # AI patent counts (PatentsView Search API; key required)

# Optional overrides (defaults shown).
AI_DEPTH_DB="data/evidence.sqlite"
AI_DEPTH_RAW_DIR="data/raw"
AI_DEPTH_EXPORT_DIR="data/exports"
REQUEST_TIMEOUT="30"
MAX_CANDIDATE_PARAGRAPHS="40"
